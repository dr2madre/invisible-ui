{
  "component": "search-dialog",
  "selected": false,
  "props": [
    {
      "name": "triggerVariant",
      "type": "\"default\" | \"primary\" | \"secondary\" | \"ghost\" | \"danger\"",
      "default": "\"default\"",
      "required": false,
      "description": "Visual variant for the trigger Button."
    },
    {
      "name": "items",
      "type": "SearchDialogItem[]",
      "default": null,
      "required": true,
      "description": ""
    },
    {
      "name": "open",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "title",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Accessible title for the dialog. Defaults to the i18n catalog's \"Search\"."
    },
    {
      "name": "label",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Accessible label for the search input. Defaults to the i18n catalog's \"Search\"."
    },
    {
      "name": "placeholder",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Input placeholder. Defaults to the i18n catalog's \"Type to search…\"."
    },
    {
      "name": "emptyText",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Text shown when nothing matches. Defaults to the i18n catalog's \"No results found.\"."
    },
    {
      "name": "onSelect",
      "type": "((value: string) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": ""
    },
    {
      "name": "onOpenChange",
      "type": "((o: boolean) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": ""
    }
  ]
}
