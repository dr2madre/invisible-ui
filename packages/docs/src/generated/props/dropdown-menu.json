{
  "component": "dropdown-menu",
  "selected": false,
  "props": [
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": true,
      "description": ""
    },
    {
      "name": "items",
      "type": "MenuItem[]",
      "default": null,
      "required": true,
      "description": ""
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "onSelect",
      "type": "((value: string) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called with the chosen item's value."
    }
  ]
}
