{
  "component": "switch",
  "selected": false,
  "props": [
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": true,
      "description": "Accessible, visible label; override with the default slot."
    },
    {
      "name": "checked",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "On/off state."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "Disable the control."
    },
    {
      "name": "name",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Form field name; the value is submitted under it when on."
    },
    {
      "name": "value",
      "type": "string",
      "default": "\"on\"",
      "required": false,
      "description": "Value submitted with the form when on."
    },
    {
      "name": "required",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "Mark the control required for native form validation."
    },
    {
      "name": "onCheckedChange",
      "type": "((c: boolean) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called whenever the value changes."
    }
  ]
}
