{
  "component": "time-field",
  "selected": false,
  "props": [
    {
      "name": "value",
      "type": "string | null",
      "default": "null",
      "required": false,
      "description": ""
    },
    {
      "name": "hourCycle",
      "type": "HourCycle",
      "default": "24",
      "required": false,
      "description": ""
    },
    {
      "name": "withSeconds",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "label",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Accessible label for the whole field."
    },
    {
      "name": "name",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Form field name — the formatted time is submitted under it (via a hidden input)."
    },
    {
      "name": "onValueChange",
      "type": "((value: string | null) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called with the formatted value (or `null` while incomplete)."
    }
  ]
}
