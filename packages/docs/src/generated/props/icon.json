{
  "component": "icon",
  "selected": false,
  "props": [
    {
      "name": "size",
      "type": "string",
      "default": "\"1em\"",
      "required": false,
      "description": "Width/height (scales with font-size by default)."
    },
    {
      "name": "viewBox",
      "type": "string",
      "default": "\"0 0 24 24\"",
      "required": false,
      "description": "SVG viewBox."
    },
    {
      "name": "strokeWidth",
      "type": "number | string",
      "default": "2",
      "required": false,
      "description": "Stroke width in viewBox units."
    },
    {
      "name": "label",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Accessible name; when omitted the icon is decorative."
    },
    {
      "name": "animation",
      "type": "\"none\" | \"spin\" | \"pulse\"",
      "default": "\"none\"",
      "required": false,
      "description": "Built-in animation for the glyph: `spin` (continuous rotation, e.g. a loader) or `pulse` (opacity beat, e.g. a live indicator). Both respect `prefers-reduced-motion` (the icon stays visible, static)."
    },
    {
      "name": "animationDuration",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Animation duration (any CSS time, e.g. \"0.8s\")."
    }
  ]
}
