{
  "component": "combobox",
  "selected": false,
  "props": [
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": true,
      "description": "Accessible name for the control."
    },
    {
      "name": "items",
      "type": "(ComboboxItem & { icon?: string })[]",
      "default": null,
      "required": true,
      "description": "Options: `{ value, label?, disabled? }`."
    },
    {
      "name": "value",
      "type": "string | null",
      "default": "null",
      "required": false,
      "description": "Selected value."
    },
    {
      "name": "searchable",
      "type": "boolean",
      "default": "true",
      "required": false,
      "description": "With `searchable={false}` the text input becomes read-only and the list always shows every option — a select-only combobox: the advanced Select (styled popup, per-option icons) without the autocomplete."
    },
    {
      "name": "width",
      "type": "\"wrap\" | \"fill\" | \"fixed\"",
      "default": "\"fixed\"",
      "required": false,
      "description": "Width behaviour: `fixed` (default) uses `--ds-combobox-width` (16rem), `wrap` fits the longest option, `fill` takes 100% of the container."
    },
    {
      "name": "placeholder",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Input placeholder."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "Disable the control."
    },
    {
      "name": "clearLabel",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Accessible label for the clear button."
    },
    {
      "name": "emptyText",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Shown when nothing matches."
    },
    {
      "name": "name",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Form field name — the selected option's value is submitted under it (via a hidden input)."
    },
    {
      "name": "onValueChange",
      "type": "((value: string | null) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called when the selection changes."
    },
    {
      "name": "onInputValueChange",
      "type": "((text: string) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called when the input text changes."
    }
  ]
}
