{
  "component": "context-menu",
  "selected": false,
  "props": [
    {
      "name": "items",
      "type": "MenuItem[]",
      "default": null,
      "required": true,
      "description": ""
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "onSelect",
      "type": "((value: string) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called with the chosen item's value."
    },
    {
      "name": "label",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Accessible name for the popup (there is no labelling trigger)."
    }
  ]
}
