{
  "component": "tabs",
  "selected": false,
  "props": [
    {
      "name": "items",
      "type": "TabsItem[]",
      "default": null,
      "required": true,
      "description": ""
    },
    {
      "name": "value",
      "type": "string | null",
      "default": "null",
      "required": false,
      "description": ""
    },
    {
      "name": "activationMode",
      "type": "ActivationMode",
      "default": "\"automatic\"",
      "required": false,
      "description": ""
    },
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": true,
      "description": "Accessible name for the tab list."
    },
    {
      "name": "onValueChange",
      "type": "((value: string) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called whenever the selected tab changes."
    }
  ]
}
