{
  "component": "progress",
  "selected": false,
  "props": [
    {
      "name": "value",
      "type": "number | null",
      "default": "0",
      "required": false,
      "description": "Completion (`null` = indeterminate)."
    },
    {
      "name": "min",
      "type": "number",
      "default": "0",
      "required": false,
      "description": "Range bounds."
    },
    {
      "name": "max",
      "type": "number",
      "default": "100",
      "required": false,
      "description": "Range bounds."
    },
    {
      "name": "shape",
      "type": "\"bar\" | \"circle\"",
      "default": "\"bar\"",
      "required": false,
      "description": "Shape: a linear `bar` (default) or a `circle` ring (upload/export)."
    },
    {
      "name": "showValue",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "Show the percentage inside the circle (determinate `circle` only)."
    },
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": true,
      "description": "Accessible name."
    }
  ]
}
