{
  "component": "table",
  "selected": false,
  "props": [
    {
      "name": "columns",
      "type": "TableColumnDef[]",
      "default": null,
      "required": true,
      "description": "Columns (`{ key, header, sortable?, align?, hideable? }`)."
    },
    {
      "name": "rows",
      "type": "TableRow[]",
      "default": null,
      "required": true,
      "description": "Row objects keyed by `column.key`."
    },
    {
      "name": "sort",
      "type": "SortState | null",
      "default": "null",
      "required": false,
      "description": "Current sort (`{ key, direction }`)."
    },
    {
      "name": "onSortToggle",
      "type": "((key: string) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called when a sortable header is toggled."
    },
    {
      "name": "caption",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Accessible caption."
    },
    {
      "name": "hideCaption",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "Visually hide the caption."
    },
    {
      "name": "getValue",
      "type": "(row: TableRow, key: string) => unknown",
      "default": "(row, key) => row[key]",
      "required": false,
      "description": "Read a cell value (override for nested/derived data)."
    },
    {
      "name": "getRowId",
      "type": "(row: TableRow, index: number) => string | number",
      "default": "(row, index) =>",
      "required": false,
      "description": "Stable row key."
    }
  ]
}
