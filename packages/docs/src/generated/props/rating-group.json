{
  "component": "rating-group",
  "selected": false,
  "props": [
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": true,
      "description": "Accessible group name."
    },
    {
      "name": "max",
      "type": "number",
      "default": "5",
      "required": false,
      "description": "Number of stars."
    },
    {
      "name": "value",
      "type": "number | null",
      "default": "null",
      "required": false,
      "description": "Current rating."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "Disable the group."
    },
    {
      "name": "name",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Form field name — the rating is submitted under it."
    },
    {
      "name": "onValueChange",
      "type": "((value: number) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called when the rating changes."
    }
  ]
}
