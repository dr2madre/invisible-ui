{
  "component": "toggle-button",
  "selected": false,
  "props": [
    {
      "name": "pressed",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "label",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Accessible name; required when the slot is icon-only."
    },
    {
      "name": "name",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Form field name — when checked, submits `value` under it."
    },
    {
      "name": "value",
      "type": "string",
      "default": "\"on\"",
      "required": false,
      "description": "Value submitted under `name` when pressed."
    },
    {
      "name": "onPressedChange",
      "type": "((p: boolean) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called whenever `pressed` changes."
    }
  ]
}
