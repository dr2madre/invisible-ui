{
  "component": "notification",
  "selected": false,
  "props": [
    {
      "name": "status",
      "type": "NotificationStatus",
      "default": "\"info\"",
      "required": false,
      "description": "Feedback status: `info` | `success` | `warning` | `danger` | `neutral`."
    },
    {
      "name": "title",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": ""
    },
    {
      "name": "text",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": ""
    },
    {
      "name": "duration",
      "type": "number",
      "default": "0",
      "required": false,
      "description": "Auto-dismiss delay in ms — opt-in. `0` (default) keeps it until closed."
    },
    {
      "name": "closable",
      "type": "boolean",
      "default": "true",
      "required": false,
      "description": ""
    },
    {
      "name": "role",
      "type": "\"status\" | \"alert\"",
      "default": "\"status\"",
      "required": false,
      "description": ""
    },
    {
      "name": "actions",
      "type": "NotificationAction[] | undefined",
      "default": "undefined",
      "required": false,
      "description": ""
    },
    {
      "name": "inverted",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": "High-contrast inverse surface for maximum visibility. Recommended for transient info outcomes that auto-dismiss (saved, offline, downtime…)."
    },
    {
      "name": "iconShape",
      "type": "\"rounded\" | \"round\"",
      "default": "\"rounded\"",
      "required": false,
      "description": "Shape of the FeedbackIcon box — `\"rounded\"` (default) or a full `\"round\"` circle."
    },
    {
      "name": "iconBox",
      "type": "\"tint\" | \"transparent\" | \"solid\" | undefined",
      "default": "undefined",
      "required": false,
      "description": "FeedbackIcon box override (see InlineNotification): force `\"tint\"`/`\"solid\"` on a tinted surface."
    },
    {
      "name": "onclose",
      "type": "(() => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called when the notification is dismissed (auto, close button, or action)."
    }
  ]
}
