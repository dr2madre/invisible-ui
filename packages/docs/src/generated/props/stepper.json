{
  "component": "stepper",
  "selected": false,
  "props": [
    {
      "name": "steps",
      "type": "StepDescriptor[]",
      "default": null,
      "required": true,
      "description": ""
    },
    {
      "name": "current",
      "type": "number",
      "default": "0",
      "required": false,
      "description": ""
    },
    {
      "name": "linear",
      "type": "boolean",
      "default": "true",
      "required": false,
      "description": ""
    },
    {
      "name": "orientation",
      "type": "\"horizontal\" | \"vertical\"",
      "default": "\"horizontal\"",
      "required": false,
      "description": ""
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "label",
      "type": "string",
      "default": "\"Progress\"",
      "required": false,
      "description": "Accessible name."
    },
    {
      "name": "onStepChange",
      "type": "((current: number) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called when the active step changes."
    }
  ]
}
