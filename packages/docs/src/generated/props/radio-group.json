{
  "component": "radio-group",
  "selected": false,
  "props": [
    {
      "name": "items",
      "type": "RadioGroupItem[]",
      "default": null,
      "required": true,
      "description": ""
    },
    {
      "name": "value",
      "type": "string | null",
      "default": "null",
      "required": false,
      "description": ""
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": "false",
      "required": false,
      "description": ""
    },
    {
      "name": "orientation",
      "type": "Orientation",
      "default": "\"vertical\"",
      "required": false,
      "description": "Layout direction."
    },
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": true,
      "description": "Accessible name for the group."
    },
    {
      "name": "name",
      "type": "string | undefined",
      "default": "undefined",
      "required": false,
      "description": "Form field name — the selected value is submitted under it (auto-generated for grouping if omitted)."
    },
    {
      "name": "onValueChange",
      "type": "((value: string) => void) | undefined",
      "default": "undefined",
      "required": false,
      "description": "Called whenever the selected value changes."
    }
  ]
}
