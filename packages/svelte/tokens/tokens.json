{
  "palette": {
    "$type": "color",
    "blue": {
      "600": { "$value": "#527acc" },
      "700": { "$value": "#1d4ed8" }
    },
    "violet": {
      "600": { "$value": "oklch(54.5% 0.181 295.2)" },
      "700": { "$value": "oklch(48.5% 0.181 295.2)" }
    },
    "green": {
      "400": { "$value": "oklch(78.3% 0.129 138.7)" },
      "500": { "$value": "oklch(72.3% 0.129 138.7)" },
      "600": { "$value": "#16a34a" }
    },
    "amber": {
      "600": { "$value": "#e58a2e" }
    },
    "red": {
      "600": { "$value": "#dc2626" },
      "700": { "$value": "#b91c1c" }
    },
    "grey": {
      "0": { "$value": "#ffffff" },
      "50": { "$value": "#fafaf9" },
      "100": { "$value": "#f5f5f4" },
      "200": { "$value": "#e7e5e4" },
      "300": { "$value": "#d6d3d1" },
      "400": { "$value": "#a8a29e" },
      "500": { "$value": "#78716c" },
      "600": { "$value": "#57534e" },
      "700": { "$value": "#44403c" },
      "800": { "$value": "#292524" },
      "900": { "$value": "#1c1917" },
      "950": { "$value": "#0c0a09" }
    }
  },
  "style": {
    "$type": "color",
    "primary": {
      "default": { "$value": "{palette.green.400}" },
      "hover": { "$value": "{palette.green.500}" }
    },
    "secondary": {
      "default": { "$value": "{palette.violet.600}" },
      "hover": { "$value": "{palette.violet.700}" }
    },
    "info": {
      "default": { "$value": "{palette.blue.600}" }
    },
    "success": {
      "default": { "$value": "{palette.green.600}" }
    },
    "warning": {
      "default": { "$value": "{palette.amber.600}" }
    },
    "danger": {
      "default": { "$value": "{palette.red.600}" },
      "hover": { "$value": "{palette.red.700}" }
    }
  },
  "radius": {
    "$type": "dimension",
    "control": { "$value": "0.5rem" },
    "surface": { "$value": "0.75rem" },
    "pill": { "$value": "999px" }
  }
}
