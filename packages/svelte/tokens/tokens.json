{
  "palette": {
    "$type": "color",
    "purple": {
      "500": { "$value": "#7a52cc" },
      "600": { "$value": "#6840b7" }
    },
    "blue": {
      "500": { "$value": "#4067b6" }
    },
    "orange": {
      "500": { "$value": "#c96422" }
    },
    "green": {
      "600": { "$value": "#3e7523" }
    },
    "red": {
      "600": { "$value": "#be3b50" },
      "700": { "$value": "#ab2e42" }
    },
    "grey": {
      "0": { "$value": "#ffffff" },
      "50": { "$value": "#f4f2ef" },
      "100": { "$value": "#e6e0d8" },
      "200": { "$value": "#c7c1b7" },
      "300": { "$value": "#a8a297" },
      "400": { "$value": "#757067" },
      "500": { "$value": "#5e5951" },
      "600": { "$value": "#524c44" },
      "700": { "$value": "#413c36" },
      "800": { "$value": "#332f2a" },
      "900": { "$value": "#282420" },
      "950": { "$value": "#1c1915" }
    }
  },
  "style": {
    "$type": "color",
    "primary": {
      "default": { "$value": "{palette.purple.500}" },
      "hover": { "$value": "{palette.purple.600}" }
    },
    "secondary": {
      "default": { "$value": "{palette.purple.500}" },
      "hover": { "$value": "{palette.purple.600}" }
    },
    "info": {
      "default": { "$value": "{palette.blue.500}" }
    },
    "success": {
      "default": { "$value": "{palette.green.600}" }
    },
    "warning": {
      "default": { "$value": "{palette.orange.500}" }
    },
    "danger": {
      "default": { "$value": "{palette.red.600}" },
      "hover": { "$value": "{palette.red.700}" }
    }
  },
  "radius": {
    "$type": "dimension",
    "control": { "$value": "0.5rem" },
    "surface": { "$value": "0.75rem" },
    "pill": { "$value": "999px" }
  }
}
