{
  "name": "@design-system/core",
  "version": "0.1.0-alpha.0",
  "description": "Framework-agnostic state, behavior and accessibility logic for the design system.",
  "license": "EUPL-1.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dr2madre/design-system.git",
    "directory": "core"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
